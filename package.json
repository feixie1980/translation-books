{
  "name": "translation-books",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Translate web-novel raws (Korean -> Chinese) with the Claude API and build epub/pdf.",
  "bin": {
    "book-translate": "src/cli.ts"
  },
  "scripts": {
    "book": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "epub-gen-memory": "^1.1.2",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.8.0",
    "puppeteer": "^23.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "puppeteer"]
  }
}
